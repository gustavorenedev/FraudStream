{
  "ConnectionStrings": {
    "Postgres": "Host=postgres;Port=5432;Database=fraudstream;Username=fraud_user;Password=fraud_pass",
    "Redis": "redis:6379"
  },
  "RabbitMq": {
    "Host": "rabbitmq",
    "VHost": "/",
    "Username": "guest",
    "Password": "guest"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://seq:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ]
  },
  "AllowedHosts": "*"
}